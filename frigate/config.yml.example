mqtt:
  enabled: true
  host: mosquitto
  port: 1883
  user: "{FRIGATE_MQTT_USER}"
  password: "{FRIGATE_MQTT_PASSWORD}"

go2rtc:
  streams:
    gate01_main:
      - "rtsp://{FRIGATE_HIKVISION_USER}:{FRIGATE_HIKVISION_PASSWORD}@{FRIGATE_HIKVISION_HOST}:554/Streaming/Channels/101"
    gate01_sub:
      - "rtsp://{FRIGATE_HIKVISION_USER}:{FRIGATE_HIKVISION_PASSWORD}@{FRIGATE_HIKVISION_HOST}:554/Streaming/Channels/102"

ffmpeg:
  hwaccel_args: preset-nvidia

detect:
  # Python YOLO/ByteTrack remains the analytics layer.
  enabled: false

record:
  enabled: true
  continuous:
    days: 14

cameras:
  gate01:
    enabled: true
    ffmpeg:
      inputs:
        - path: rtsp://127.0.0.1:8554/gate01_main
          input_args: preset-rtsp-restream
          roles:
            - record
        - path: rtsp://127.0.0.1:8554/gate01_sub
          input_args: preset-rtsp-restream
          roles:
            - detect
