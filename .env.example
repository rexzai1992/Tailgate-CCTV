FRIGATE_BASE_URL=http://localhost:5000/api
FRIGATE_PUBLIC_URL=http://localhost:8971
FRIGATE_INTERNAL_PORT=5000
FRIGATE_USERNAME=admin
FRIGATE_PASSWORD=changeme
FRIGATE_EVENT_PRE_ROLL_SECONDS=3
FRIGATE_EVENT_POST_ROLL_SECONDS=5
FRIGATE_REQUEST_TIMEOUT_SECONDS=8
FRIGATE_CAMERA_NAME=gate01

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=frigate
MQTT_PASSWORD=changeme
MQTT_ANALYTICS_TOPIC_PREFIX=analytics/events

USE_FRIGATE_BRIDGE=true
USE_MQTT_ANALYTICS_EVENTS=true
USE_FRIGATE_MANUAL_EVENTS=true
USE_FRIGATE_EXPORTS=true

# Used only by the Frigate container/config example.
HIKVISION_HOST=192.168.1.64
HIKVISION_USERNAME=admin
HIKVISION_PASSWORD=changeme
TZ=Asia/Kuala_Lumpur
